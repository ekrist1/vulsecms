{
  "name": "@vulse/dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm -r --filter @vulse/db --filter @vulse/renderer --filter @vulse/auth --filter @vulse/core --filter @vulse/site build",
    "dev": "vite",
    "build": "vite build && vite build -c vite.config.server.ts",
    "start": "node dist/server/server.prod.js",
    "check": "vue-tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate-to-turso": "node scripts/migrate-to-turso.mjs"
  },
  "dependencies": {
    "@vulse/admin": "workspace:*",
    "@vulse/auth": "workspace:*",
    "@vulse/core": "workspace:*",
    "@vulse/db": "workspace:*",
    "@vulse/site": "workspace:*",
    "h3": "^1.15.11",
    "pinia": "^2.2.4",
    "vue": "^3.5.0",
    "vue-router": "^4.4.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-beta.3",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "tailwindcss": "^4.0.0-beta.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "vue-tsc": "^2.1.10"
  }
}
