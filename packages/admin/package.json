{
  "name": "@vulse/admin",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Vue 3 admin SPA for Vulse. Consumed as source via Vite.",
  "publishConfig": { "access": "public" },
  "type": "module",
  "files": ["src"],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles.css"
  },
  "scripts": {
    "build": "vue-tsc -p tsconfig.json --noEmit && vite build",
    "check": "vue-tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tiptap/core": "^2.8.0",
    "@tiptap/extension-document": "^2.8.0",
    "@tiptap/pm": "^2.8.0",
    "@tiptap/starter-kit": "^2.8.0",
    "@tiptap/vue-3": "^2.8.0",
    "@vulse/renderer": "workspace:*",
    "pinia": "^2.2.4",
    "reka-ui": "^1.0.0-alpha.10",
    "vue": "^3.5.0",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-beta.3",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.0.0-beta.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "vue-tsc": "^2.1.10"
  }
}
