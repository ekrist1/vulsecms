{
  "name": "@vulse/host",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Composable helpers that wire @vulse/core + @vulse/auth + @vulse/db + @vulse/site into a runnable app.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@vulse/auth": "workspace:*",
    "@vulse/core": "workspace:*",
    "@vulse/db": "workspace:*",
    "@vulse/image": "workspace:*",
    "@vulse/site": "workspace:*",
    "h3": "^1.15.11"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
