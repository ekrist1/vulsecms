{
  "name": "@vulse/astro",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Astro Content Layer loader for Vulse CMS — sync collections, drafts, and previews into your Astro site.",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "astro": "^4.14.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "astro": { "optional": false }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
