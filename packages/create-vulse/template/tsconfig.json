{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src/**/*", "server/**/*", "blueprints/**/*", "modules/**/*", "vulse.config.ts"]
}
